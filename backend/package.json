{
  "name": "interviewai-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup src/index.ts --format cjs --dts --out-dir dist",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^10.0.1",
    "@supabase/supabase-js": "^2.45.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.1",
    "postgres": "^3.4.4",
    "stripe": "^16.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
