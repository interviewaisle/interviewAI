PORT=3001
CORS_ORIGIN=http://localhost:3000

# Supabase — Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase — Settings > Database > Connection string (Transaction pooler)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Redis — local docker-compose or managed (e.g. Upstash)
REDIS_URL=redis://localhost:6379

# Stripe — dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Code execution — Judge0 CE (free, no key needed for ce.judge0.com)
# Self-host: https://github.com/judge0/judge0
JUDGE0_URL=https://ce.judge0.com

# AI provider — set ONE of the following:
# Option A: Groq (hosted, free tier) — console.groq.com → API Keys
GROQ_API_KEY=
# Option B: Ollama (local dev only) — default, no key needed
OLLAMA_URL=http://localhost:11434
